{
  "name": "Sepur_tours_management",
  "version": "1.0.0",
  "description": "Digitalisation des tournées de collecte et gestion des roadmaps — SAP CAP/Fiori",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "generate:unit-tests": "node tools/generate-ui5-unit-tests.js",
    "watch-login": "cds watch --open sepur.login/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-tours": "cds watch --open ns.tours/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-roadmaps": "cds watch --open ns.roadmaps/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy Sepur_tours_management --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-supervisor-tours": "cds watch --open sepur.supervisor.supervisortours/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-supervisor-roadmaps": "cds watch --open sepur.supervisor.supervisorroadmaps/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-supervisor-dashboard-fiori": "cds watch --open sepur.supervisor.supervisordashboardfiori/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/login",
    "app/planner-dashboard",
    "app/supervisor-dashboard",
    "app/tours",
    "app/roadmaps",
    "app/supervisor-tours",
    "app/supervisor-roadmaps",
    "app/supervisor-dashboard-fiori"
  ],
  "cds": {
    "requires": {
      "[development]": {
        "db": {
          "kind": "sqlite"
        },
        "auth": {
          "kind": "dummy"
        }
      }
    }
  }
}
