{
  "_version": "1.49.0",
  "sap.app": {
    "id": "sepur.supervisor",
    "type": "application",
    "title": "Dashboard Superviseur",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.viz": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "rootView": {
      "viewName": "sepur.supervisor.view.Dashboard",
      "type": "XML",
      "id": "dashboard",
      "async": true
    },
    "models": {
      "": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "settings": {
          "serviceUrl": "/odata/v4/route-management/",
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "view": {
        "type": "sap.ui.model.json.JSONModel"
      }
    }
  }
}