<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    controllerName="sepur.planner.controller.Dashboard"
    displayBlock="true">

    <App id="dashboardApp">
        <Page showHeader="false" class="plannerPage">
            <content>

                <HBox id="layoutRoot" class="layoutRoot">

                    <!-- SIDEBAR FIXE -->
                    <VBox id="sidebar" class="sideNav">

                        <VBox class="brandArea" alignItems="Center">
                            <Image
                                src="https://www.sepur.com/wp-content/uploads/2025/01/logo-sepur-insertion-e1736954850722.png"
                                class="sepurLogo"
                                decorative="false"
                                alt="SEPUR" />

                            <Text text="Planification" class="brandSubtitle" />
                        </VBox>

                        <VBox class="menuArea">
                            <Button
                                text="Dashboard"
                                icon="sap-icon://business-objects-experience"
                                class="menuButton activeMenu"
                                press=".onRefresh" />

                            <Button
                                text="Tournées"
                                icon="sap-icon://map"
                                class="menuButton"
                                press=".onOpenTours" />

                            <Button
                                text="Roadmaps"
                                icon="sap-icon://journey-arrive"
                                class="menuButton"
                                press=".onOpenRoadmaps" />

                            <Button
                                text="Tournées rejetées"
                                icon="sap-icon://message-error"
                                class="menuButton"
                                press=".onOpenRejectedTours" />

                            <Button
                                text="Accueil"
                                icon="sap-icon://grid"
                                class="menuButton"
                                press=".onOpenHome" />
                        </VBox>

                        <VBox class="bottomArea">
                            <Button
                                text="Actualiser"
                                icon="sap-icon://refresh"
                                class="menuButton"
                                press=".onRefresh" />

                            <Button
                                text="Déconnexion"
                                icon="sap-icon://log"
                                class="menuButton logoutButton"
                                press=".onLogout" />
                        </VBox>

                    </VBox>

                    <!-- MAIN AREA -->
                    <VBox id="mainContent" class="mainArea" busy="{/busy}" busyIndicatorDelay="0">

                        <!-- HEADER FIXE SANS LOGO SAP -->
                        <HBox class="topBar" justifyContent="SpaceBetween" alignItems="Center">

                            <HBox alignItems="Center" class="headerBrand">
                                <VBox>
                                    <Title text="Espace Planificateur" level="H2" class="topTitle" />
                                    <Text text="Suivi des tournées, roadmaps, validations et rejets" class="topSubtitle" />
                                </VBox>
                            </HBox>

                            <HBox alignItems="Center" class="topActions">
                                <Button
                                    text="Créer une tournée"
                                    icon="sap-icon://add"
                                    type="Emphasized"
                                    press=".onCreateTour"
                                    class="btnCreate sapUiSmallMarginEnd" />

                                <Button
                                    icon="sap-icon://refresh"
                                    type="Default"
                                    tooltip="Actualiser les données"
                                    press=".onRefresh"
                                    class="refreshButton sapUiSmallMarginEnd" />

                                <Avatar
                                    initials="{/userInitials}"
                                    displaySize="S"
                                    backgroundColor="Accent6"
                                    class="topAvatar" />
                            </HBox>

                        </HBox>

                        <!-- BODY SCROLLABLE -->
                        <VBox class="dashboardBody">

                            <!-- KPI CARDS SAP FIORI NATIF -->
                            <HBox
                                class="sectionHeader"
                                justifyContent="SpaceBetween"
                                alignItems="Center">

                                <VBox>
                                    <Title
                                        text="Indicateurs clés"
                                        level="H3"
                                        class="sectionTitle" />

                                    <Text
                                        text="Vue rapide des volumes et statuts opérationnels"
                                        class="sectionSubtitle" />
                                </VBox>
                            </HBox>

                            <f:GridContainer
                                id="kpiGrid"
                                class="kpiGridProfessional">

                                <f:layout>
                                    <f:GridContainerSettings
                                        rowSize="5rem"
                                        columnSize="11rem"
                                        gap="1rem" />
                                </f:layout>

                                <!-- Total tournées -->
                                <GenericTile
                                    header="Total tournées"
                                    subheader="Toutes les tournées enregistrées"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenTours">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="Tournées">
                                            <NumericContent
                                                value="{/stats/totalTours}"
                                                icon="sap-icon://map"
                                                valueColor="Neutral"
                                                indicator="None"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                                <!-- Tournées créées -->
                                <GenericTile
                                    header="Tournées créées"
                                    subheader="En attente de traitement"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenTours">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="À suivre">
                                            <NumericContent
                                                value="{/stats/createdTours}"
                                                icon="sap-icon://pending"
                                                valueColor="Critical"
                                                indicator="None"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                                <!-- Tournées validées -->
                                <GenericTile
                                    header="Tournées validées"
                                    subheader="Acceptées par le superviseur"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenTours">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="Validées">
                                            <NumericContent
                                                value="{/stats/validatedTours}"
                                                icon="sap-icon://accept"
                                                valueColor="Good"
                                                indicator="Up"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                                <!-- Tournées rejetées -->
                                <GenericTile
                                    header="Tournées rejetées"
                                    subheader="Correction nécessaire"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenRejectedTours">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="À corriger">
                                            <NumericContent
                                                value="{/stats/rejectedTours}"
                                                icon="sap-icon://message-error"
                                                valueColor="Error"
                                                indicator="Down"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                                <!-- Total roadmaps -->
                                <GenericTile
                                    header="Total roadmaps"
                                    subheader="Roadmaps disponibles"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenRoadmaps">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="Roadmaps">
                                            <NumericContent
                                                value="{/stats/totalRoadmaps}"
                                                icon="sap-icon://journey-arrive"
                                                valueColor="Neutral"
                                                indicator="None"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                                <!-- Roadmaps créées -->
                                <GenericTile
                                    header="Roadmaps créées"
                                    subheader="En attente de traitement"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenRoadmaps">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="À traiter">
                                            <NumericContent
                                                value="{/stats/createdRoadmaps}"
                                                icon="sap-icon://pending"
                                                valueColor="Critical"
                                                indicator="None"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                                <!-- Roadmaps validées -->
                                <GenericTile
                                    header="Roadmaps validées"
                                    subheader="Acceptées par le superviseur"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenRoadmaps">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="Validées">
                                            <NumericContent
                                                value="{/stats/validatedRoadmaps}"
                                                icon="sap-icon://accept"
                                                valueColor="Good"
                                                indicator="Up"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                                <!-- Roadmaps rejetées -->
                                <GenericTile
                                    header="Roadmaps rejetées"
                                    subheader="Correction nécessaire"
                                    frameType="TwoByOne"
                                    class="sapKpiTile"
                                    press=".onOpenRejectedTours">

                                    <layoutData>
                                        <f:GridContainerItemLayoutData
                                            columns="2"
                                            minRows="2" />
                                    </layoutData>

                                    <tileContent>
                                        <TileContent footer="À corriger">
                                            <NumericContent
                                                value="{/stats/rejectedRoadmaps}"
                                                icon="sap-icon://message-error"
                                                valueColor="Error"
                                                indicator="Down"
                                                withMargin="false" />
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>

                            </f:GridContainer>

                            <!-- QUICK NAVIGATION -->
                            <HBox class="quickNav" justifyContent="Center" alignItems="Center" wrap="Wrap">
                                <Button text="Tournées" icon="sap-icon://map" class="quickButton activeQuick" press=".onOpenTours" />
                                <Button text="Roadmaps" icon="sap-icon://journey-arrive" class="quickButton" press=".onOpenRoadmaps" />
                                <Button text="Tournées rejetées" icon="sap-icon://message-error" class="quickButton" press=".onOpenRejectedTours" />
                                <Button text="Actualiser" icon="sap-icon://refresh" class="quickButton" press=".onRefresh" />
                            </HBox>

                            <!-- CHARTS UNIQUEMENT -->
                            <HBox class="chartsRow" wrap="Wrap">

                                <VBox class="chartCard">
                                    <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://donut-chart" class="cardHeaderIcon" />
                                            <VBox>
                                                <Title text="Statistiques des tournées" level="H4" class="cardTitle" />
                                                <Text text="Répartition par statut" class="mutedText" />
                                            </VBox>
                                        </HBox>

                                        <Button
                                            icon="sap-icon://refresh"
                                            type="Transparent"
                                            press=".onRefresh"
                                            tooltip="Actualiser" />
                                    </HBox>

                                    <viz:VizFrame
                                        id="tourStatusChart"
                                        uiConfig="{applicationSet:'fiori'}"
                                        vizType="donut"
                                        width="100%"
                                        height="300px">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{/tourChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Statut" value="{status}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Nombre" value="{total}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Nombre" />
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Statut" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </VBox>

                                <VBox class="chartCard">
                                    <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                                        <HBox alignItems="Center">
                                            <core:Icon src="sap-icon://bar-chart" class="cardHeaderIcon" />
                                            <VBox>
                                                <Title text="Statistiques des roadmaps" level="H4" class="cardTitle" />
                                                <Text text="Répartition par statut" class="mutedText" />
                                            </VBox>
                                        </HBox>

                                        <Button
                                            icon="sap-icon://refresh"
                                            type="Transparent"
                                            press=".onRefresh"
                                            tooltip="Actualiser" />
                                    </HBox>

                                    <viz:VizFrame
                                        id="roadmapStatusChart"
                                        uiConfig="{applicationSet:'fiori'}"
                                        vizType="column"
                                        width="100%"
                                        height="300px">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{/roadmapChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Statut" value="{status}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Nombre" value="{total}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Nombre" />
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Statut" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </VBox>

                            </HBox>

                        </VBox>

                    </VBox>

                </HBox>

            </content>
        </Page>
    </App>
</mvc:View>