<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    controllerName="sepur.planner.controller.Dashboard"
    displayBlock="true">

    <App id="dashboardApp">
        <Page showHeader="false" class="plannerPage">
            <content>

                <HBox id="layoutRoot" class="layoutRoot">

                    <!-- SIDEBAR FIXE -->
                    <VBox id="sidebar" class="sideNav">

                        <VBox class="brandArea" alignItems="Center">
                            <Image
                                src="https://www.sepur.com/wp-content/uploads/2025/01/logo-sepur-insertion-e1736954850722.png"
                                class="sepurLogo"
                                decorative="false"
                                alt="SEPUR" />

                            <!-- <Text text="Planification" class="brandSubtitle" /> -->
                        </VBox>

                        <VBox class="menuArea">
                            <Button
                                text="Dashboard"
                                icon="sap-icon://business-objects-experience"
                                class="menuButton activeMenu"
                                press=".onRefresh" />

                            <Button
                                text="Tournées"
                                icon="sap-icon://map"
                                class="menuButton"
                                press=".onOpenTours" />

                            <Button
                                text="Roadmaps"
                                icon="sap-icon://journey-arrive"
                                class="menuButton"
                                press=".onOpenRoadmaps" />

                            <Button
                                text="Tournées rejetées"
                                icon="sap-icon://decline"
                                class="menuButton"
                                press=".onOpenRejectedTours" />

                            <Button
                                text="Accueil"
                                icon="sap-icon://grid"
                                class="menuButton"
                                press=".onOpenHome" />
                        </VBox>

                        <VBox class="bottomArea">
                            <Button
                                text="Actualiser"
                                icon="sap-icon://refresh"
                                class="menuButton"
                                press=".onRefresh" />

                            <Button
                                text="Déconnexion"
                                icon="sap-icon://log"
                                class="menuButton logoutButton"
                                press=".onLogout" />
                        </VBox>

                    </VBox>

                    <!-- MAIN AREA -->
                    <VBox id="mainContent" class="mainArea" busy="{/busy}" busyIndicatorDelay="0">

                        <!-- HEADER FIXE -->
                        <HBox class="topBar" justifyContent="SpaceBetween" alignItems="Center">

                            <HBox alignItems="Center" class="headerBrand">
                                <VBox>
                                    <Title text="Espace Planificateur" level="H2" class="topTitle" />
                                    <Text text="Suivi des tournées, roadmaps, validations et rejets" class="topSubtitle" />
                                </VBox>
                            </HBox>

                            <HBox alignItems="Center" class="topActions">


                                <Button
                                    id="btnPlannerNotifications"
                                    icon="sap-icon://bell"
                                    text="{/notifications/unreadCount}"
                                    tooltip="Notifications"
                                    press=".onOpenNotifications"
                                    class="notificationButton sapUiSmallMarginBegin" />

                                <Button
                                    icon="sap-icon://refresh"
                                    type="Default"
                                    tooltip="Actualiser les données"
                                    press=".onRefresh"
                                    class="refreshButton sapUiSmallMarginBegin" />

                                <Avatar
                                    initials="{/userInitials}"
                                    displaySize="S"
                                    backgroundColor="Accent6"
                                    class="topAvatar" />
                            </HBox>

                        </HBox>

                        <!-- BODY SCROLLABLE -->
                        <VBox class="dashboardBody">

                            <!-- <VBox class="sectionHeader">
                                <Title text="Indicateurs clés" level="H3" class="sectionTitle" />
                                <Text text="Vue rapide des volumes et statuts opérationnels" class="sectionSubtitle" />
                            </VBox> -->

                            <!-- KPI CARDS -->
                            <FlexBox
    id="kpiGrid"
    class="kpiGridProfessional"
    wrap="Wrap"
    justifyContent="Start"
    alignItems="Start">

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Total tournées" class="kpiCleanTitle" />
            <Text text="Toutes les tournées enregistrées" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://map" class="kpiCleanIcon kpiNeutral" />
            <Title text="{/stats/totalTours}" level="H1" class="kpiCleanNumber kpiNeutral" />
        </HBox>

        <Text text="Tournées" class="kpiCleanFooter" />
    </VBox>

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Tournées créées" class="kpiCleanTitle" />
            <Text text="En attente de traitement" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://synchronize" class="kpiCleanIcon kpiCritical" />
            <Title text="{/stats/createdTours}" level="H1" class="kpiCleanNumber kpiCritical" />
        </HBox>

        <Text text="À suivre" class="kpiCleanFooter" />
    </VBox>

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Tournées validées" class="kpiCleanTitle" />
            <Text text="Acceptées par le superviseur" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://accept" class="kpiCleanIcon kpiGood" />
            <Title text="{/stats/validatedTours}" level="H1" class="kpiCleanNumber kpiGood" />
            <core:Icon src="sap-icon://trend-up" class="kpiTrendIcon kpiGood" />
        </HBox>

        <Text text="Validées" class="kpiCleanFooter" />
    </VBox>

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Tournées rejetées" class="kpiCleanTitle" />
            <Text text="Correction nécessaire" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://decline" class="kpiCleanIcon kpiError" />
            <Title text="{/stats/rejectedTours}" level="H1" class="kpiCleanNumber kpiError" />
            <core:Icon src="sap-icon://trend-down" class="kpiTrendIcon kpiError" />
        </HBox>

        <Text text="À corriger" class="kpiCleanFooter" />
    </VBox>

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Total roadmaps" class="kpiCleanTitle" />
            <Text text="Roadmaps disponibles" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://journey-arrive" class="kpiCleanIcon kpiNeutral" />
            <Title text="{/stats/totalRoadmaps}" level="H1" class="kpiCleanNumber kpiNeutral" />
        </HBox>

        <Text text="Roadmaps" class="kpiCleanFooter" />
    </VBox>

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Roadmaps créées" class="kpiCleanTitle" />
            <Text text="En attente de traitement" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://synchronize" class="kpiCleanIcon kpiCritical" />
            <Title text="{/stats/createdRoadmaps}" level="H1" class="kpiCleanNumber kpiCritical" />
        </HBox>

        <Text text="À traiter" class="kpiCleanFooter" />
    </VBox>

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Roadmaps validées" class="kpiCleanTitle" />
            <Text text="Acceptées par le superviseur" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://accept" class="kpiCleanIcon kpiGood" />
            <Title text="{/stats/validatedRoadmaps}" level="H1" class="kpiCleanNumber kpiGood" />
            <core:Icon src="sap-icon://trend-up" class="kpiTrendIcon kpiGood" />
        </HBox>

        <Text text="Validées" class="kpiCleanFooter" />
    </VBox>

    <VBox class="kpiCleanCard">
        <VBox>
            <Text text="Roadmaps rejetées" class="kpiCleanTitle" />
            <Text text="Correction nécessaire" class="kpiCleanSubtitle" />
        </VBox>

        <HBox class="kpiCleanValueRow" alignItems="Center">
            <core:Icon src="sap-icon://decline" class="kpiCleanIcon kpiError" />
            <Title text="{/stats/rejectedRoadmaps}" level="H1" class="kpiCleanNumber kpiError" />
            <core:Icon src="sap-icon://trend-down" class="kpiTrendIcon kpiError" />
        </HBox>

        <Text text="À corriger" class="kpiCleanFooter" />
    </VBox>

</FlexBox>

                            <!-- CHARTS -->
                            <HBox class="chartsRow" wrap="Wrap">

                                <VBox class="chartCard">
                                    <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                                        <HBox alignItems="Center">
                                            <VBox class="cardIconBox">
                                                <core:Icon src="sap-icon://donut-chart" class="cardHeaderIcon" />
                                            </VBox>
                                            <VBox>
                                                <Title text="Statistiques des tournées" level="H4" class="cardTitle" />
                                                <Text text="Répartition par statut" class="mutedText" />
                                            </VBox>
                                        </HBox>

                                        <Button
                                            icon="sap-icon://refresh"
                                            type="Transparent"
                                            press=".onRefresh"
                                            tooltip="Actualiser" />
                                    </HBox>

                                    <viz:VizFrame
                                        id="tourStatusChart"
                                        uiConfig="{applicationSet:'fiori'}"
                                        vizType="donut"
                                        width="100%"
                                        height="300px">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{/tourChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Statut" value="{status}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Nombre" value="{total}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Nombre" />
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Statut" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </VBox>

                                <VBox class="chartCard">
                                    <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                                        <HBox alignItems="Center">
                                            <VBox class="cardIconBox">
                                                <core:Icon src="sap-icon://bar-chart" class="cardHeaderIcon" />
                                            </VBox>
                                            <VBox>
                                                <Title text="Statistiques des roadmaps" level="H4" class="cardTitle" />
                                                <Text text="Répartition par statut" class="mutedText" />
                                            </VBox>
                                        </HBox>

                                        <Button
                                            icon="sap-icon://refresh"
                                            type="Transparent"
                                            press=".onRefresh"
                                            tooltip="Actualiser" />
                                    </HBox>

                                    <viz:VizFrame
                                        id="roadmapStatusChart"
                                        uiConfig="{applicationSet:'fiori'}"
                                        vizType="column"
                                        width="100%"
                                        height="300px">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{/roadmapChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Statut" value="{status}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Nombre" value="{total}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Nombre" />
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Statut" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </VBox>

                            </HBox>

                        </VBox>

                    </VBox>

                </HBox>

            </content>
        </Page>
    </App>
</mvc:View>