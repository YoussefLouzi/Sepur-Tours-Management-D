<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sepur.planner.controller.Dashboard"
    displayBlock="true">

    <App>
        <Page showHeader="false" class="plannerPage">
            <content>

                <HBox class="layoutRoot">

                    <VBox class="sideNav">

                        <HBox class="brandBox" alignItems="Center">
                            <Image
                                src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/SAP_2011_logo.svg/1280px-SAP_2011_logo.svg.png"
                                class="brandLogo"
                                decorative="false" />
                            <Text text="SEPUR" class="brandText" />
                        </HBox>

                        <VBox class="menuBox">
                            <Button text="Dashboard" icon="sap-icon://business-objects-experience" class="menuButton activeMenu" press=".onRefresh" />
                            <Button text="Tournées" icon="sap-icon://map" class="menuButton" press=".onOpenTours" />
                            <Button text="Roadmaps" icon="sap-icon://journey-arrive" class="menuButton" press=".onOpenRoadmaps" />
                            <Button text="Clients" icon="sap-icon://customer" class="menuButton" />
                            <Button text="Véhicules" icon="sap-icon://shipping-status" class="menuButton" />
                            <Button text="Chauffeurs" icon="sap-icon://employee" class="menuButton" />
                            <Button text="Paramètres" icon="sap-icon://action-settings" class="menuButton" />
                        </VBox>

                        <VBox class="logoutBox">
                            <Button text="Réduire" icon="sap-icon://slim-arrow-left" class="menuButton" />
                            <Button text="Déconnexion" icon="sap-icon://log" class="menuButton dangerMenu" press=".onLogout" />
                        </VBox>

                    </VBox>

                    <VBox class="mainArea">

                        <HBox class="topBar" justifyContent="SpaceBetween" alignItems="Center">
                            <VBox>
                                <Title text="Espace de Paramétrage" level="H2" class="topTitle" />
                                <Text text="Dashboard Planificateur" class="topSubTitle" />
                            </VBox>

                            <HBox alignItems="Center">
                                <Button
                                    text="Créer une tournée"
                                    icon="sap-icon://add"
                                    type="Emphasized"
                                    press=".onCreateTour"
                                    class="sapUiSmallMarginEnd" />

                                <Avatar
                                    initials="{/userInitials}"
                                    displaySize="XS"
                                    backgroundColor="Accent6" />
                            </HBox>
                        </HBox>

                        <HBox class="moduleTabs" alignItems="Center">
                            <VBox class="moduleItem activeModule">
                                <Text text="🏠" class="moduleIcon" />
                                <Text text="Dashboard" class="moduleText" />
                            </VBox>
                            <VBox class="moduleItem">
                                <Text text="🚚" class="moduleIcon" />
                                <Text text="Tournées" class="moduleText" />
                            </VBox>
                            <VBox class="moduleItem">
                                <Text text="🧭" class="moduleIcon" />
                                <Text text="Roadmaps" class="moduleText" />
                            </VBox>
                            <VBox class="moduleItem">
                                <Text text="👤" class="moduleIcon" />
                                <Text text="Clients" class="moduleText" />
                            </VBox>
                            <VBox class="moduleItem">
                                <Text text="⚙️" class="moduleIcon" />
                                <Text text="Paramètres" class="moduleText" />
                            </VBox>
                        </HBox>

                        <HBox class="statsRow" wrap="Wrap">

                            <VBox class="statCard">
                                <Text text="Total tournées" class="statLabel" />
                                <ObjectNumber number="{/stats/totalTours}" class="statNumber" />
                            </VBox>

                            <VBox class="statCard">
                                <Text text="Brouillons" class="statLabel" />
                                <ObjectNumber number="{/stats/draftTours}" class="statNumber" />
                            </VBox>

                            <VBox class="statCard orange">
                                <Text text="En attente" class="statLabel" />
                                <ObjectNumber number="{/stats/pendingTours}" class="statNumber" />
                            </VBox>

                            <VBox class="statCard green">
                                <Text text="Acceptées" class="statLabel" />
                                <ObjectNumber number="{/stats/acceptedTours}" class="statNumber" />
                            </VBox>

                            <VBox class="statCard red">
                                <Text text="Rejetées" class="statLabel" />
                                <ObjectNumber number="{/stats/rejectedTours}" class="statNumber" />
                            </VBox>

                            <VBox class="statCard blue">
                                <Text text="Roadmaps" class="statLabel" />
                                <ObjectNumber number="{/stats/totalRoadmaps}" class="statNumber" />
                            </VBox>

                        </HBox>

                        <HBox class="contentRow" wrap="Wrap">

                            <VBox class="chartCard">
                                <Title text="Répartition des tournées par statut" level="H4" class="cardTitle" />

                                <VBox class="barChart">

                                    <HBox class="barItem" alignItems="Center">
                                        <Text text="Brouillons" class="barLabel" />
                                        <ProgressIndicator percentValue="{/chart/draftPercent}" displayValue="{/stats/draftTours}" class="barProgress" />
                                    </HBox>

                                    <HBox class="barItem" alignItems="Center">
                                        <Text text="En attente" class="barLabel" />
                                        <ProgressIndicator percentValue="{/chart/pendingPercent}" displayValue="{/stats/pendingTours}" state="Warning" class="barProgress" />
                                    </HBox>

                                    <HBox class="barItem" alignItems="Center">
                                        <Text text="Acceptées" class="barLabel" />
                                        <ProgressIndicator percentValue="{/chart/acceptedPercent}" displayValue="{/stats/acceptedTours}" state="Success" class="barProgress" />
                                    </HBox>

                                    <HBox class="barItem" alignItems="Center">
                                        <Text text="Rejetées" class="barLabel" />
                                        <ProgressIndicator percentValue="{/chart/rejectedPercent}" displayValue="{/stats/rejectedTours}" state="Error" class="barProgress" />
                                    </HBox>

                                </VBox>
                            </VBox>

                            <VBox class="tableCard">
                                <HBox justifyContent="SpaceBetween" alignItems="Center" class="cardHeader">
                                    <VBox>
                                        <Title text="Dernières tournées" level="H4" class="cardTitle" />
                                        <Text text="Dernière mise à jour : aujourd’hui" class="mutedText" />
                                    </VBox>

                                    <Button icon="sap-icon://refresh" press=".onRefresh" />
                                </HBox>

                                <Table
                                    items="{/tours}"
                                    growing="true"
                                    growingThreshold="5"
                                    noDataText="Aucune tournée disponible.">

                                    <columns>
                                        <Column><Text text="Code" /></Column>
                                        <Column><Text text="Date" /></Column>
                                        <Column><Text text="Zone" /></Column>
                                        <Column><Text text="Statut" /></Column>
                                        <Column><Text text="Action" /></Column>
                                    </columns>

                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <ObjectIdentifier title="{tourCode}" />
                                                <Text text="{tourDate}" />
                                                <Text text="{zone}" />
                                                <ObjectStatus text="{status}" state="{path:'status', formatter:'.formatStatusState'}" />
                                                <Button icon="sap-icon://navigation-right-arrow" type="Transparent" press=".onOpenTours" />
                                            </cells>
                                        </ColumnListItem>
                                    </items>

                                </Table>
                            </VBox>

                        </HBox>

                    </VBox>

                </HBox>

            </content>
        </Page>
    </App>
</mvc:View>