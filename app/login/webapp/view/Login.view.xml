<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sepur.login.controller.Login"
    displayBlock="true">

    <App>
        <Page title="SEPUR — Connexion" showHeader="true">
            <content>
                <VBox
                    width="100%"
                    height="100%"
                    alignItems="Center"
                    justifyContent="Center"
                    class="sapUiLargeMarginTop">

                    <Panel
                        headerText="Connexion à l'application"
                        width="30rem"
                        class="sapUiResponsiveMargin">

                        <VBox class="sapUiSmallMargin">

                            <Title
                                text="Gestion des tournées de collecte"
                                level="H3"
                                class="sapUiSmallMarginBottom" />

                            <Label text="Nom d'utilisateur" required="true" />
                            <Input
                                id="inpUsername"
                                value="{/username}"
                                placeholder="planificateur"
                                width="100%" />

                            <Label
                                text="Mot de passe"
                                required="true"
                                class="sapUiSmallMarginTop" />
                            <Input
                                id="inpPassword"
                                type="Password"
                                value="{/password}"
                                placeholder="Mot de passe"
                                width="100%" />

                            <Button
                                text="Se connecter"
                                type="Emphasized"
                                press=".onLogin"
                                width="100%"
                                class="sapUiMediumMarginTop" />

                            <MessageStrip
                                id="msgError"
                                text=""
                                type="Error"
                                visible="false"
                                showIcon="true"
                                class="sapUiSmallMarginTop" />

                        </VBox>
                    </Panel>
                </VBox>
            </content>
        </Page>
    </App>
</mvc:View>