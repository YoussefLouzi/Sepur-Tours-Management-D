<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sepur.login.controller.Login"
    displayBlock="true">

    <App>
        <Page showHeader="false" class="loginPage">
            <content>
                <VBox class="loginShell" alignItems="Center" justifyContent="Center">

                    <VBox class="loginCard">

                        <VBox class="loginHeader" alignItems="Center">
                            <Image
                                src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/SAP_2011_logo.svg/1280px-SAP_2011_logo.svg.png"
                                class="sapLogoImage"
                                decorative="false"
                                alt="SAP Logo" />

                            <Title
                                text="SEPUR Tours Management"
                                level="H2"
                                textAlign="Center"
                                class="loginTitle" />

                            <Text
                                text="Gestion digitale des tournées et roadmaps"
                                textAlign="Center"
                                class="loginSubtitle" />
                        </VBox>

                        <VBox class="loginForm">

                            <Label
                                text="E-mail ou nom d'utilisateur"
                                required="true"
                                class="loginLabel" />

                            <Input
                                id="inpUsername"
                                value="{/username}"
                                placeholder="planificateur ou superviseur"
                                width="100%"
                                class="loginInput sapStyleInput" />

                            <Label
                                text="Mot de passe"
                                required="true"
                                class="loginLabel passwordLabel" />

                            <Input
                                id="inpPassword"
                                type="Password"
                                value="{/password}"
                                placeholder="Mot de passe"
                                width="100%"
                                submit=".onLogin"
                                showValueHelp="true"
                                valueHelpIconSrc="sap-icon://show"
                                valueHelpRequest=".onTogglePasswordVisibility"
                                class="loginInput sapStyleInput passwordInput" />

                            <HBox
                                justifyContent="SpaceBetween"
                                alignItems="Center"
                                class="loginOptions">

                                <CheckBox
                                    text="Rester connecté"
                                    selected="false"
                                    class="rememberCheck" />

                                <Link
                                    text="Mot de passe oublié ?"
                                    press=".onForgotPassword"
                                    class="forgotLink" />
                            </HBox>

                            <Button
                                text="Se connecter"
                                type="Emphasized"
                                press=".onLogin"
                                width="100%"
                                class="loginButton" />

                            <MessageStrip
                                id="msgError"
                                text=""
                                type="Error"
                                visible="false"
                                showIcon="true"
                                class="sapUiSmallMarginTop" />

                        </VBox>

                        <VBox class="loginFooter" alignItems="Center">
                            <Text
                                text="© SEPUR — Powered by SAP BTP"
                                class="footerText" />
                        </VBox>

                    </VBox>

                </VBox>
            </content>
        </Page>
    </App>
</mvc:View>