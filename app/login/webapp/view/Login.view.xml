<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sepur.login.controller.Login"
    displayBlock="true">

    <App>
        <Page showHeader="false" class="loginPage">
            <content>
                <VBox class="loginShell" alignItems="Center" justifyContent="Center">

                    <VBox class="loginCard">

                       <VBox alignItems="Center" class="loginHeader">

    <Image
        src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/SAP_2011_logo.svg/1280px-SAP_2011_logo.svg.png"
        alt="SAP Logo"
        decorative="false"
        class="sapLogoImage" />

    <Title
        text="SEPUR Tours Management"
        level="H2"
        textAlign="Center"
        class="loginTitle" />

    <Text
        text="Gestion digitale des tournées et roadmaps"
        textAlign="Center"
        class="loginSubtitle" />

</VBox>

                        <VBox class="loginForm">

                            <Label text="Compte utilisateur" class="loginLabel" />
                            <Input
                                id="inpUsername"
                                value="{/username}"
                                placeholder="planificateur ou superviseur"
                                width="100%"
                                class="loginInput" />

                            <Label text="Mot de passe" class="loginLabel sapUiSmallMarginTop" />
                            <Input
                                id="inpPassword"
                                type="Password"
                                value="{/password}"
                                placeholder="Mot de passe"
                                width="100%"
                                class="loginInput"
                                submit=".onLogin" />

                            <HBox justifyContent="End" class="forgotBox">
                                <Link
                                    text="Mot de passe oublié ?"
                                    press=".onForgotPassword" />
                            </HBox>

                            <Button
                                text="Se connecter"
                                type="Emphasized"
                                press=".onLogin"
                                width="100%"
                                class="loginButton" />

                            <MessageStrip
                                id="msgError"
                                text=""
                                type="Error"
                                visible="false"
                                showIcon="true"
                                class="sapUiSmallMarginTop" />

                        </VBox>

                        <VBox alignItems="Center" class="loginFooter">
                            <Text text="© SEPUR — SAP BTP CAP Fiori" class="footerText" />
                        </VBox>

                    </VBox>

                </VBox>
            </content>
        </Page>
    </App>
</mvc:View>