{
  "_version": "1.85.0",
  "sap.app": {
    "id": "sepur.supervisor.supervisorroadmaps",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/route-management/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sepur.supervisor.supervisorroadmaps.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true,
          "synchronizationMode": "None"
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "SupervisorRoadmapsList",
          "target": "SupervisorRoadmapsList"
        },
        {
          "pattern": "Roadmaps({key}):?query:",
          "name": "SupervisorRoadmapsObjectPage",
          "target": "SupervisorRoadmapsObjectPage"
        }
      ],
      "targets": {
        "SupervisorRoadmapsList": {
          "type": "Component",
          "id": "SupervisorRoadmapsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Roadmaps",
              "variantManagement": "None",
              "initialLoad": "Enabled",
              "hideDraftToggle": true,
              "creationMode": {
                "name": "Disabled"
              },
              "content": {
                "header": {
                  "actions": {
                    "RetourSupervisorDashboard": {
                      "text": "Retour au dashboard",
                      "press": "sepur.supervisor.supervisorroadmaps.ext.controller.SupervisorRoadmapActions.onBackToDashboard",
                      "visible": true,
                      "enabled": true
                    }
                  }
                }
              },
              "navigation": {
                "Roadmaps": {
                  "detail": {
                    "route": "SupervisorRoadmapsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Multi",
                    "selectAll": true,
                    "enableExport": true,
                    "personalization": {
                      "column": true,
                      "sort": true,
                      "filter": true,
                      "group": true
                    }
                  },
                  "actions": {
                    "ValidateSelectedRoadmap": {
                      "text": "Valider",
                      "press": "sepur.supervisor.supervisorroadmaps.ext.controller.SupervisorRoadmapActions.onValidateRoadmap",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true
                    },
                    "RejectSelectedRoadmap": {
                      "text": "Rejeter",
                      "press": "sepur.supervisor.supervisorroadmaps.ext.controller.SupervisorRoadmapActions.onRejectRoadmap",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true
                    }
                  }
                }
              }
            }
          }
        },
        "SupervisorRoadmapsObjectPage": {
          "type": "Component",
          "id": "SupervisorRoadmapsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/Roadmaps",
              "editableHeaderContent": false,
              "showRelatedApps": false,
              "sectionLayout": "Page",
              "content": {
                "header": {
                  "actions": {
                    "ValidateRoadmapObjectPage": {
                      "text": "Valider",
                      "press": "sepur.supervisor.supervisorroadmaps.ext.controller.SupervisorRoadmapActions.onValidateRoadmap",
                      "visible": true,
                      "enabled": true
                    },
                    "RejectRoadmapObjectPage": {
                      "text": "Rejeter",
                      "press": "sepur.supervisor.supervisorroadmaps.ext.controller.SupervisorRoadmapActions.onRejectRoadmap",
                      "visible": true,
                      "enabled": true
                    },
                    "BackObjectPage": {
                      "text": "Retour",
                      "press": "sepur.supervisor.supervisorroadmaps.ext.controller.SupervisorRoadmapActions.onBack",
                      "visible": true,
                      "enabled": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    },
    "macros": {
      "table": {}
    }
  }
}