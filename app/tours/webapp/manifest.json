{
  "_version": "1.85.0",
  "sap.app": {
    "id": "ns.tours",
    "type": "application",
    "i18n": {
      "bundleUrl": "i18n/i18n.properties",
      "supportedLocales": ["fr", ""],
      "fallbackLocale": "fr"
    },
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.25.0",
      "toolsId": "60405abc-4135-4c29-8271-e6721bcdaec8"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/route-management/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ns.tours.i18n.i18n",
          "supportedLocales": ["fr", ""],
          "fallbackLocale": "fr"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties",
        "settings": {
          "supportedLocales": ["fr", ""],
          "fallbackLocale": "fr"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ToursList",
          "target": "ToursList"
        },
        {
          "pattern": "Tours({key}):?query:",
          "name": "ToursObjectPage",
          "target": "ToursObjectPage"
        }
      ],
      "targets": {
        "ToursList": {
          "type": "Component",
          "id": "ToursList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Tours",
  "variantManagement": "Page",
  "initialLoad": "Enabled",
              "content": {
                "header": {
                  "actions": {
                    "RetourDashboardList": {
                      "text": "Retour au tableau de bord",
                      "press": "ns.tours.ext.controller.ListReportActions.onBackToDashboard",
                      "visible": true,
                      "enabled": true,
                      "buttonType": "Transparent"
                    }
                  }
                }
              },
              "navigation": {
                "Tours": {
                  "detail": {
                    "route": "ToursObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "enableExport": true,
                    "personalization": {
                      "column": true,
                      "sort": true,
                      "filter": true,
                      "group": true
                    }
                  },
                  "actions": {
                    "CreateRoadmapFromTour": {
                      "text": "Créer une feuille de route",
                      "press": "ns.tours.ext.controller.ListReportActions.onCreateRoadmapFromTour",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "buttonType": "Emphasized"
                    }
                  }
                }
              }
            }
          }
        },
        "ToursObjectPage": {
          "type": "Component",
          "id": "ToursObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Tours",
              "showRelatedApps": false,
              "sectionLayout": "Page",
              "content": {
                "header": {
                  "actions": {
                    "CreateRoadmapFromTourObjectPage": {
                      "text": "Créer une feuille de route",
                      "press": "ns.tours.ext.controller.ListReportActions.onCreateRoadmapFromTour",
                      "visible": true,
                      "enabled": true,
                      "buttonType": "Emphasized"
                    },
                    "RetourBackObjectPage": {
                      "text": "Retour",
                      "press": "ns.tours.ext.controller.ListReportActions.onBack",
                      "visible": true,
                      "enabled": true,
                      "buttonType": "Transparent"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
