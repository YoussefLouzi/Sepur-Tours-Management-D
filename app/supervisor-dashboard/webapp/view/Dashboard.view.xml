<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    controllerName="sepur.supervisor.controller.Dashboard"
    displayBlock="true">

    <App>
        <Page showHeader="false" class="supervisorPage">
            <content>

                <HBox class="pageLayout">

                    <!-- SIDEBAR FIXE -->
                    <VBox class="sideNav">

                        <VBox class="brandArea" alignItems="Center">
                            <Image
                                src="https://www.sepur.com/wp-content/uploads/2025/01/logo-sepur-insertion-e1736954850722.png"
                                class="sepurLogo"
                                decorative="false"
                                alt="SEPUR" />

                            <Text text="Supervision" class="brandSubtitle" />
                        </VBox>

                        <VBox class="menuArea">
                            <Button
                                text="Dashboard"
                                icon="sap-icon://business-objects-experience"
                                class="menuButton activeMenu"
                                press=".onDashboard" />

                            <Button
                                text="Tournées"
                                icon="sap-icon://map"
                                class="menuButton"
                                press=".onOpenTours" />

                            <Button
                                text="Roadmaps"
                                icon="sap-icon://journey-arrive"
                                class="menuButton"
                                press=".onOpenRoadmaps" />

                            <Button
                                text="Sales Orders"
                                icon="sap-icon://sales-order"
                                class="menuButton"
                                press=".onSelectSalesOrders" />

                            <Button
                                text="Historique"
                                icon="sap-icon://history"
                                class="menuButton"
                                press=".onSelectHistory" />
                        </VBox>

                        <VBox class="bottomArea">
                            <Button
                                text="Déconnexion"
                                icon="sap-icon://log"
                                class="menuButton logoutButton"
                                press=".onLogout" />
                        </VBox>

                    </VBox>

                    <!-- MAIN AREA -->
                    <VBox class="mainArea" busy="{view>/busy}" busyIndicatorDelay="0">

                        <!-- HEADER FIXE -->
                        <HBox class="topBar" justifyContent="SpaceBetween" alignItems="Center">

                            <HBox alignItems="Center" class="headerBrand">
                                <Image
                                    src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/SAP_2011_logo.svg/1280px-SAP_2011_logo.svg.png"
                                    class="sapHeaderLogo"
                                    decorative="false"
                                    alt="SAP" />

                                <VBox>
                                    <Title text="Espace Superviseur" level="H2" class="topTitle" />
                                    <Text text="Suivi des tournées, roadmaps, commandes et décisions" class="topSubtitle" />
                                </VBox>
                            </HBox>

                            <HBox alignItems="Center">
                                <Button
                                    id="btnNotifications"
                                    icon="sap-icon://bell"
                                    text="{view>/notifications/count}"
                                    tooltip="Notifications"
                                    press=".onOpenNotifications"
                                    class="notificationButton sapUiSmallMarginEnd" />

                                <Button
                                    icon="sap-icon://refresh"
                                    tooltip="Actualiser"
                                    press=".onRefresh"
                                    class="refreshButton sapUiSmallMarginEnd" />

                                <Avatar
                                    initials="{view>/userInitials}"
                                    displaySize="S"
                                    backgroundColor="Accent6"
                                    class="topAvatar" />
                            </HBox>

                        </HBox>

                        <!-- BODY -->
                        <VBox class="dashboardBody">

                            <!-- KPI CARDS -->
                            <FlexBox class="kpiGrid" wrap="Wrap">

                                <VBox class="kpiCard kpiBlue">
                                    <HBox justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox>
                                            <Text text="Total tournées" class="kpiTitle" />
                                            <Text text="Créées dans le système" class="kpiSubtitle" />
                                        </VBox>
                                        <core:Icon src="sap-icon://map" class="kpiIcon kpiIconBlue" />
                                    </HBox>
                                    <Title text="{view>/tourStats/totalTours}" level="H1" class="kpiNumber kpiNumBlue" />
                                    <Text text="Total enregistré" class="kpiFooter" />
                                </VBox>

                                <VBox class="kpiCard kpiOrange">
                                    <HBox justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox>
                                            <Text text="En attente" class="kpiTitle" />
                                            <Text text="À valider" class="kpiSubtitle" />
                                        </VBox>
                                        <core:Icon src="sap-icon://pending" class="kpiIcon kpiIconOrange" />
                                    </HBox>
                                    <Title text="{view>/tourStats/pendingTours}" level="H1" class="kpiNumber kpiNumOrange" />
                                    <Text text="Tournées à traiter" class="kpiFooter" />
                                </VBox>

                                <VBox class="kpiCard kpiGreen">
                                    <HBox justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox>
                                            <Text text="Acceptées" class="kpiTitle" />
                                            <Text text="Validées" class="kpiSubtitle" />
                                        </VBox>
                                        <core:Icon src="sap-icon://accept" class="kpiIcon kpiIconGreen" />
                                    </HBox>
                                    <Title text="{view>/tourStats/acceptedTours}" level="H1" class="kpiNumber kpiNumGreen" />
                                    <Text text="Décisions positives" class="kpiFooter" />
                                </VBox>

                                <VBox class="kpiCard kpiRed">
                                    <HBox justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox>
                                            <Text text="Rejetées" class="kpiTitle" />
                                            <Text text="À corriger" class="kpiSubtitle" />
                                        </VBox>
                                        <core:Icon src="sap-icon://message-error" class="kpiIcon kpiIconRed" />
                                    </HBox>
                                    <Title text="{view>/tourStats/rejectedTours}" level="H1" class="kpiNumber kpiNumRed" />
                                    <Text text="Retour planificateur" class="kpiFooter" />
                                </VBox>

                                <VBox class="kpiCard kpiPurple">
                                    <HBox justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox>
                                            <Text text="Roadmaps" class="kpiTitle" />
                                            <Text text="Générées" class="kpiSubtitle" />
                                        </VBox>
                                        <core:Icon src="sap-icon://journey-arrive" class="kpiIcon kpiIconPurple" />
                                    </HBox>
                                    <Title text="{view>/roadmapStats/totalRoadmaps}" level="H1" class="kpiNumber kpiNumPurple" />
                                    <Text text="Roadmaps disponibles" class="kpiFooter" />
                                </VBox>

                                <VBox class="kpiCard kpiBlue">
                                    <HBox justifyContent="SpaceBetween" alignItems="Start">
                                        <VBox>
                                            <Text text="Sales Orders" class="kpiTitle" />
                                            <Text text="Commandes clients" class="kpiSubtitle" />
                                        </VBox>
                                        <core:Icon src="sap-icon://sales-order" class="kpiIcon kpiIconBlue" />
                                    </HBox>
                                    <Title text="{view>/salesOrderStats/totalSalesOrders}" level="H1" class="kpiNumber kpiNumBlue" />
                                    <Text text="Commandes générées" class="kpiFooter" />
                                </VBox>

                            </FlexBox>

                            <!-- QUICK NAVIGATION -->
                            <HBox class="quickNav" justifyContent="Center" alignItems="Center">
                                <Button text="Tournées" icon="sap-icon://map" class="quickButton activeQuick" press=".onOpenTours" />
                                <Button text="Roadmaps" icon="sap-icon://journey-arrive" class="quickButton" press=".onOpenRoadmaps" />
                                <Button text="Sales Orders" icon="sap-icon://sales-order" class="quickButton" press=".onSelectSalesOrders" />
                                <Button text="Historique" icon="sap-icon://history" class="quickButton" press=".onSelectHistory" />
                                <Button text="Actualiser" icon="sap-icon://refresh" class="quickButton" press=".onRefresh" />
                            </HBox>

                            <!-- CHARTS : CERCLE + BARRES -->
                            <HBox class="chartsRow" wrap="Wrap">

                                <VBox class="chartCard">
                                    <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                                        <VBox>
                                            <Title text="Répartition des tournées" level="H4" class="cardTitle" />
                                            <Text text="En attente, acceptées et rejetées" class="mutedText" />
                                        </VBox>
                                        <Button icon="sap-icon://refresh" type="Transparent" press=".onRefresh" />
                                    </HBox>

                                    <viz:VizFrame
                                        id="supervisorTourDonutChart"
                                        uiConfig="{applicationSet:'fiori'}"
                                        vizType="donut"
                                        width="100%"
                                        height="270px">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{view>/tourDonutData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Statut" value="{view>label}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Total" value="{view>value}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Total" />
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Statut" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </VBox>

                                <VBox class="chartCard">
                                    <HBox class="cardHeader" justifyContent="SpaceBetween" alignItems="Center">
                                        <VBox>
                                            <Title text="Statistiques des roadmaps" level="H4" class="cardTitle" />
                                            <Text text="Répartition par statut" class="mutedText" />
                                        </VBox>
                                        <Button icon="sap-icon://refresh" type="Transparent" press=".onRefresh" />
                                    </HBox>

                                    <viz:VizFrame
                                        id="supervisorRoadmapBarChart"
                                        uiConfig="{applicationSet:'fiori'}"
                                        vizType="column"
                                        width="100%"
                                        height="270px">

                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{view>/roadmapBarData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Statut" value="{view>label}" />
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Nombre" value="{view>value}" />
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>

                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Nombre" />
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Statut" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </VBox>

                            </HBox>

                            <!-- RÉSUMÉ BAS -->
                            <HBox class="summaryRow" wrap="Wrap">

                                <VBox class="summaryCard">
                                    <HBox alignItems="Center" class="summaryHeader">
                                        <core:Icon src="sap-icon://journey-arrive" class="summaryIcon" />
                                        <VBox>
                                            <Title text="État des roadmaps" level="H4" class="summaryTitle" />
                                            <Text text="Vue rapide des roadmaps générées" class="summarySubtitle" />
                                        </VBox>
                                    </HBox>

                                    <HBox class="miniStats" wrap="Wrap">
                                        <ObjectStatus text="{= 'Brouillon : ' + ${view>/roadmapStats/draftRoadmaps} }" state="Warning" />
                                        <ObjectStatus text="{= 'Actives : ' + ${view>/roadmapStats/activeRoadmaps} }" state="Information" />
                                        <ObjectStatus text="{= 'Terminées : ' + ${view>/roadmapStats/completedRoadmaps} }" state="Success" />
                                        <ObjectStatus text="{= 'Annulées : ' + ${view>/roadmapStats/cancelledRoadmaps} }" state="Error" />
                                    </HBox>
                                </VBox>

                                <VBox class="summaryCard">
                                    <HBox alignItems="Center" class="summaryHeader">
                                        <core:Icon src="sap-icon://history" class="summaryIcon" />
                                        <VBox>
                                            <Title text="Historique des décisions" level="H4" class="summaryTitle" />
                                            <Text text="Suivi des validations et rejets" class="summarySubtitle" />
                                        </VBox>
                                    </HBox>

                                    <HBox class="miniStats" wrap="Wrap">
                                        <ObjectStatus text="{= 'Total : ' + ${view>/historyStats/totalDecisions} }" state="Information" />
                                        <ObjectStatus text="{= 'Acceptées : ' + ${view>/historyStats/acceptedDecisions} }" state="Success" />
                                        <ObjectStatus text="{= 'Rejetées : ' + ${view>/historyStats/rejectedDecisions} }" state="Error" />
                                    </HBox>
                                </VBox>

                            </HBox>

                        </VBox>

                    </VBox>

                </HBox>

            </content>
        </Page>
    </App>
</mvc:View>