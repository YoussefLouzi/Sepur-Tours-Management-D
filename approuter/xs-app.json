{
  "welcomeFile": "/home/webapp/index.html",
  "authenticationMethod": "none",
  "routes": [
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "route-management-api",
      "authenticationType": "none",
      "csrfProtection": true
    },
    {
      "source": "^/resources/(.*)$",
      "target": "/resources/$1",
      "destination": "ui5",
      "authenticationType": "none"
    },
    {
      "source": "^/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "destination": "ui5",
      "authenticationType": "none"
    },
    {
      "source": "^/home/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/home",
      "authenticationType": "none"
    },
    {
      "source": "^/login/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/login",
      "authenticationType": "none"
    },
    {
      "source": "^/planner-dashboard/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/planner-dashboard",
      "authenticationType": "none"
    },
    {
      "source": "^/supervisor-dashboard/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/supervisor-dashboard",
      "authenticationType": "none"
    },
    {
      "source": "^/tours/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/tours",
      "authenticationType": "none"
    },
    {
      "source": "^/roadmaps/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/roadmaps",
      "authenticationType": "none"
    },
    {
      "source": "^/supervisor-tours/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/supervisor-tours",
      "authenticationType": "none"
    },
    {
      "source": "^/supervisor-roadmaps/webapp/(.*)$",
      "target": "$1",
      "localDir": "resources/supervisor-roadmaps",
      "authenticationType": "none"
    }
  ]
}
